# OpenAgent Multi-Agent Orchestration System

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/openagent

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI API
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# OpenTelemetry
OTEL_SERVICE_NAME=openagent
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# Jaeger
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Application
APP_ENV=development
LOG_LEVEL=INFO